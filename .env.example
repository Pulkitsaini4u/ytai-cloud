# ============================================================
# YouTube AI Automation - Cloud Deployment Config
# ALL services below have FREE tiers - no credit card needed
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── MongoDB Atlas (FREE) ─────────────────────────────────────
# Sign up: https://www.mongodb.com/cloud/atlas/register
# Free tier: 512MB shared cluster, no credit card needed
# Format: mongodb+srv://user:pass@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASS@cluster0.xxxxx.mongodb.net/ytai?retryWrites=true&w=majority

# ── Upstash Redis (FREE) ──────────────────────────────────────
# Sign up: https://upstash.com (no credit card)
# Free tier: 10,000 requests/day, 256MB
# Use the REST URL + token for serverless compatibility
UPSTASH_REDIS_REST_URL=https://YOUR_UPSTASH_URL.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_TOKEN
# OR use standard Redis URL (from Upstash dashboard → "Connect" → "ioredis")
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# ── Groq API (FREE - replaces Ollama) ────────────────────────
# Sign up: https://console.groq.com (no credit card)
# Free tier: 14,400 requests/day, 6000 tokens/min
# Models: llama3-8b-8192, mixtral-8x7b-32768, gemma-7b-it
GROQ_API_KEY=gsk_YOUR_GROQ_API_KEY

# ── HuggingFace (FREE - TTS + Whisper + SD) ──────────────────
# Sign up: https://huggingface.co (free, no credit card)
# Free inference API: 30,000 chars/month for TTS
HUGGINGFACE_API_KEY=hf_YOUR_HUGGINGFACE_TOKEN

# ── Free Image APIs ───────────────────────────────────────────
# Pexels: https://www.pexels.com/api/ (free, no credit card)
PEXELS_API_KEY=YOUR_PEXELS_KEY

# Pixabay: https://pixabay.com/api/docs/ (free, no credit card)
PIXABAY_API_KEY=YOUR_PIXABAY_KEY

# ── Cloudflare R2 (FREE storage) ─────────────────────────────
# Sign up: https://cloudflare.com (free tier: 10GB storage, 1M ops/month)
# No credit card for R2 free tier
CLOUDFLARE_ACCOUNT_ID=YOUR_ACCOUNT_ID
CLOUDFLARE_R2_ACCESS_KEY=YOUR_R2_ACCESS_KEY
CLOUDFLARE_R2_SECRET_KEY=YOUR_R2_SECRET_KEY
CLOUDFLARE_R2_BUCKET=ytai-videos
CLOUDFLARE_R2_PUBLIC_URL=https://YOUR_BUCKET.YOUR_ACCOUNT.r2.dev

# ── Backblaze B2 (FREE storage - alternative to R2) ──────────
# Sign up: https://backblaze.com/b2 (free: 10GB, 1GB/day download)
# Only use ONE of R2 or B2
# B2_APPLICATION_KEY_ID=YOUR_KEY_ID
# B2_APPLICATION_KEY=YOUR_APP_KEY
# B2_BUCKET_NAME=ytai-videos
# B2_BUCKET_ID=YOUR_BUCKET_ID

# ── YouTube OAuth2 ────────────────────────────────────────────
# Guide: https://console.cloud.google.com
# Enable: YouTube Data API v3 (free: 10,000 units/day)
YOUTUBE_CLIENT_ID=YOUR_CLIENT_ID
YOUTUBE_CLIENT_SECRET=YOUR_CLIENT_SECRET
YOUTUBE_REDIRECT_URI=https://YOUR_RAILWAY_APP.railway.app/api/auth/callback
YOUTUBE_REFRESH_TOKEN=

# ── Pipeline Settings ─────────────────────────────────────────
MAX_VIDEOS_PER_DAY=2
SCRIPT_WORD_COUNT=1200
TOPICS_PER_RUN=5
GROQ_MODEL_SCRIPT=llama3-8b-8192
GROQ_MODEL_SEO=mixtral-8x7b-32768

# ── Storage mode ──────────────────────────────────────────────
# Options: r2, b2, local
STORAGE_PROVIDER=r2
LOCAL_OUTPUT_DIR=/tmp/ytai-output

# ── Cron Schedules (UTC) ──────────────────────────────────────
CRON_TOPIC_FETCH=0 6 * * *
CRON_VIDEO_GEN=0 7 * * *
CRON_UPLOAD=0 10 * * *
